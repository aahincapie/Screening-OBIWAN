# Streamlit secrets — TEMPLATE ONLY
#
# Copy to `.streamlit/secrets.toml` for local use, or paste the contents into
# Streamlit Community Cloud under:  App → Settings → Secrets
#
# `.streamlit/secrets.toml` is git-ignored. NEVER commit real credentials.
# If a key is ever pushed, revoke it in the Google Cloud console immediately —
# rotating is the only remedy, since Git history and forks outlive a deletion.

# ---------------------------------------------------------------------------
# Pilot / managed deployment
# ---------------------------------------------------------------------------
# Setting BOTH of these makes the app connect silently on load, with no sign-in
# prompt for visitors. Every Earth Engine request then bills to this project.
#
# Leave them unset for per-user authentication, where each visitor supplies
# their own project and their own quota.

EE_PROJECT_ID = "ee-geocaptain"

# Service-account key, as a TOML table. Create one with:
#
#   1. console.cloud.google.com → IAM & Admin → Service Accounts → Create
#   2. Grant it the "Earth Engine Resource Viewer" role (add "Writer" only if
#      you need Drive exports)
#   3. Keys → Add key → JSON → download
#   4. Register the service account's email for Earth Engine at
#      https://signup.earthengine.google.com/#!/service_accounts
#   5. Paste the JSON fields below
#
# The private_key must keep its literal \n sequences — do not reformat them
# into real newlines.

[EE_SERVICE_ACCOUNT_JSON]
type = "service_account"
project_id = "ee-geocaptain"
private_key_id = "REPLACE_ME"
private_key = "-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
client_email = "screening-obiwan@ee-geocaptain.iam.gserviceaccount.com"
client_id = "REPLACE_ME"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "REPLACE_ME"
universe_domain = "googleapis.com"
